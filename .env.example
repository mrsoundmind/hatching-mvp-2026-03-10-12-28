# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:5001/api/auth/google/callback"

# Session Security
SESSION_SECRET="generate-a-strong-random-secret-min-32-chars"

# DeepSeek (PRIMARY — cost-optimized, since 2026-04 price drop)
# Get key at platform.deepseek.com. V4-Pro promo (75% off) runs until 2026-05-31.
DEEPSEEK_API_KEY="sk-..."
DEEPSEEK_MODEL="deepseek-v4-flash"
DEEPSEEK_PRO_MODEL="deepseek-v4-pro"
DEEPSEEK_BASE_URL="https://api.deepseek.com/v1"

# LLM_PRIMARY — explicit override of which proprietary provider sits at head of prod chain.
# Defaults to 'deepseek' if DEEPSEEK_API_KEY is set. Set to 'gemini' to instantly roll back.
# LLM_PRIMARY=deepseek

# Gemini AI Provider (FALLBACK — kept in chain for DeepSeek outages)
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.5-flash"
# GEMINI_PRO_MODEL="gemini-2.5-pro"

# OpenAI — REMOVED from default prod chain.
# Only used in test mode (eval suite) or if explicitly set via LLM_PRIMARY=openai.
# Leave commented unless you have a specific reason to keep it.
# OPENAI_API_KEY="sk-..."
# OPENAI_MODEL="gpt-4o-mini"

# Groq (FREE tier — primary for simple chat, task extraction, conversation compaction)
# GROQ_API_KEY="gsk_..."
# GROQ_MODEL="llama-3.3-70b-versatile"

# Storage mode: "db" for PostgreSQL, "memory" for in-memory (dev only)
STORAGE_MODE=db

# LLM mode: "prod" for production, "test" for testing
# LLM_MODE=prod
# TEST_LLM_PROVIDER=mock

# App URLs
# APP_BASE_URL=http://localhost:5001
# ALLOWED_ORIGIN=http://localhost:5001

# Billing & Stripe (v1.2)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_test_...
# STRIPE_PRO_MONTHLY_PRICE_ID=price_...
# STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# Billing gates kill switch (default: true in prod, false disables all tier gating)
# FEATURE_BILLING_GATES=true

# Premium model for Pro users (autonomy/peer review) — now defaults to DeepSeek V4-Pro
# DEEPSEEK_PRO_MODEL=deepseek-v4-pro
# GEMINI_PRO_MODEL=gemini-2.5-pro

# Solo-dev cost cap — prevents runaway autonomy from blowing up bill during
# showcase production. Disabled by default. Cap is in cents per day (200 = ₹165).
# DEV_COST_CAP=true
# DAILY_COST_CAP_CENTS_DEV=200
